          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "modifiedAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@cds.on.update": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "modifiedBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@cds.on.update": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "contractID": {
          "@Core.Immutable": true,
          "@title": "Contract ID",
          "type": "cds.String",
          "length": 20,
          "notNull": true
        },
        "description": {
          "@description": true,
          "@title": "Description",
          "type": "cds.String",
          "length": 255,
          "notNull": true
        },
        "customeremail": {
          "@title": "Customer Email",
          "@dataFormat": "EMAIL",
          "type": "cds.String",
          "length": 255
        },
        "customerwebsite": {
          "@title": "Customer Website",
          "@dataFormat": "URI",
          "type": "cds.String",
          "length": 255
        },
        "status": {
          "@title": "Enum Status",
          "@assert.range": true,
          "type": "myisucontract.Status"
        },
        "priority": {
          "@title": "Enum Priority",
          "@assert.range": true,
          "type": "myisucontract.Priority"
        },
        "moveinDate": {
          "@title": "Move In Date Time",
          "type": "cds.DateTime"
        },
        "moveoutDate": {
          "@title": "Move Out Date Time",
          "type": "cds.DateTime"
        },
        "transferDate": {
          "@title": "Transfer Date",
          "type": "cds.Date"
        },
        "noofmeters": {
          "@title": "Number of Meters",
          "type": "cds.Integer"
        },
        "prioritymovein": {
          "@title": "Priority Move In",
          "type": "cds.Boolean",
          "default": {
            "val": true
          }
        },
        "moveinCharge": {
          "@title": "Move In Charge",
          "@dataFormat": "AMOUNT",
          "type": "cds.Composition",
          "target": "IsuContractCap.MoveInCharge",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "usage": {
          "@title": "Usage",
          "@dataFormat": "QUANTITY",
          "type": "cds.Composition",
          "target": "IsuContractCap.Usage",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "contact": {
          "@title": "Contact Person",
          "type": "cds.Composition",
          "target": "IsuContractCap.Contact",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "individualCustomer": {
          "@title": "Indidual Customer",
          "type": "cds.Composition",
          "target": "IsuContractCap.IndividualCustomer",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "account": {
          "@title": "Account",
          "type": "cds.Composition",
          "target": "IsuContractCap.Account",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "formattedMoveInCharge": {
          "@title": "Move In Charge",
          "@Core.Computed": true,
          "type": "cds.String"
        },
        "formattedUsage": {
          "@title": "Usage",
          "@Core.Computed": true,
          "type": "cds.String"
        }
      }
